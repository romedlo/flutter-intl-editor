{
  "name": "flutter-intl-editor",
  "displayName": "Flutter Intl Editor",
  "description": "A GUI for VS Code for editing Flutter Intl .arb files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flutterIntlExplorer",
          "title": "Flutter Intl Editor",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "flutterIntlExplorer": [
        {
          "id": "flutterIntlWelcome",
          "name": "Localization"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "flutterIntlWelcome",
        "contents": "Manage your Flutter ARB localizations seamlessly.\n\n[Open Editor](command:flutter-intl-editor.openLocalizationFile)"
      }
    ],
    "commands": [
      {
        "command": "flutter-intl-editor.openLocalizationFile",
        "title": "Open ARB File",
        "icon": "$(globe)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/nunjucks": "^3.2.6",
    "@types/vscode": "^1.87.0",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "nunjucks": "^3.2.4"
  }
}
